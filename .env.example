TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WORKSPACE_CHAT_ID=-1001234567890
TELEGRAM_MINI_APP_PUBLIC_URL=https://example.com/mini-app

DATABASE_PATH=data/telegram-codex-bridge.sqlite

CODEX_DEFAULT_CWD=~/kirbot
# One isolated home per profile; General routes to `general`, while /thread and /plan route to `coding`.
CODEX_PROFILES_JSON={"profiles":{"general":{"homePath":"~/kirbot/codex-home-general"},"coding":{"homePath":"~/kirbot/codex-home-coding"}},"routing":{"general":"general","thread":"coding","plan":"coding"}}
# Bootstrap-only for brand-new profile homes and their config.toml files:
CODEX_MODEL=
CODEX_MODEL_PROVIDER=
CODEX_SANDBOX_MODE=
CODEX_APPROVAL_POLICY=
CODEX_SERVICE_NAME=telegram-codex-bridge
CODEX_CONFIG_JSON=
