{
  "name": "kirbot-workspace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "dev": "npm run dev --workspace @kirbot/bot",
    "dev:tmux": "node scripts/tmux-session.mjs ensure dev",
    "dev:tmux:attach": "node scripts/tmux-session.mjs attach dev",
    "dev:tmux:restart": "node scripts/tmux-session.mjs restart dev",
    "generate:codex-types": "node scripts/generate-codex-types.mjs",
    "harness:telegram": "npm run harness:telegram --workspace @kirbot/bot",
    "mini-app:install": "npm install --workspace @kirbot/plan-mini-app",
    "mini-app:dev": "npm run dev --workspace @kirbot/plan-mini-app",
    "mini-app:build": "npm run build --workspace @kirbot/plan-mini-app",
    "mini-app:check": "npm run check --workspace @kirbot/plan-mini-app",
    "start": "npm run start --workspace @kirbot/bot",
    "start:tmux": "node scripts/tmux-session.mjs ensure start",
    "start:tmux:attach": "node scripts/tmux-session.mjs attach start",
    "start:tmux:restart": "node scripts/tmux-session.mjs restart start",
    "test": "node --conditions=development scripts/run-vitest.mjs run",
    "test:watch": "node --conditions=development scripts/run-vitest.mjs",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "verify:codex-types": "node scripts/check-codex-types.mjs",
    "verify:codex-upgrade": "npm run generate:codex-types && npm run typecheck && npm test"
  },
  "dependencies": {
    "@openai/codex": "0.115.0",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "grammy": "^1.38.3",
    "kysely": "^0.28.7",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm-strikethrough": "^2.0.0",
    "micromark": "^4.0.2",
    "micromark-extension-gfm-strikethrough": "^2.1.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
